terraform {
  required_providers {
    zitadel = {
      source  = "zitadel/zitadel"
      version = "{{ terrarium_zitadel_provider_version }}"
    }
  }
}

provider "zitadel" {
  domain           = "{{ terrarium_auth_domain }}"
  jwt_profile_file = "/secrets/admin-sa.json"
}

resource "zitadel_project" "terrarium" {
  name                     = "{{ terrarium_zitadel_project_name }}"
  project_role_assertion   = true
  project_role_check       = true
  has_project_check        = true
  private_labeling_setting = "PRIVATE_LABELING_SETTING_ENFORCE_PROJECT_RESOURCE_OWNER_POLICY"
}

resource "zitadel_application_oidc" "cockpit" {
  project_id = zitadel_project.terrarium.id

  name                       = "terrarium-cockpit"
  redirect_uris              = ["https://{{ terrarium_manage_domain }}/oauth2/callback"]
  response_types             = ["OIDC_RESPONSE_TYPE_CODE"]
  grant_types                = ["OIDC_GRANT_TYPE_AUTHORIZATION_CODE", "OIDC_GRANT_TYPE_REFRESH_TOKEN"]
  post_logout_redirect_uris  = ["https://{{ terrarium_manage_domain }}/"]
  app_type                   = "OIDC_APP_TYPE_WEB"
  auth_method_type           = "OIDC_AUTH_METHOD_TYPE_BASIC"
  version                    = "OIDC_VERSION_1_0"
  clock_skew                 = "0s"
  dev_mode                   = false
  access_token_type          = "OIDC_TOKEN_TYPE_BEARER"
  access_token_role_assertion = false
  id_token_role_assertion     = false
  id_token_userinfo_assertion = false
  additional_origins          = []
  skip_native_app_success_page = false

  login_version {
    login_v2 {
      base_uri = "https://{{ terrarium_auth_domain }}/ui/v2/login/"
    }
  }
}

resource "zitadel_application_oidc" "lxd" {
  project_id = zitadel_project.terrarium.id

  name                       = "terrarium-lxd"
  redirect_uris              = ["https://{{ terrarium_lxd_domain }}/oidc/callback"]
  response_types             = ["OIDC_RESPONSE_TYPE_CODE"]
  grant_types                = ["OIDC_GRANT_TYPE_AUTHORIZATION_CODE", "OIDC_GRANT_TYPE_REFRESH_TOKEN", "OIDC_GRANT_TYPE_DEVICE_CODE"]
  post_logout_redirect_uris  = ["https://{{ terrarium_lxd_domain }}/"]
  app_type                   = "OIDC_APP_TYPE_NATIVE"
  auth_method_type           = "OIDC_AUTH_METHOD_TYPE_NONE"
  version                    = "OIDC_VERSION_1_0"
  clock_skew                 = "0s"
  dev_mode                   = false
  access_token_type          = "OIDC_TOKEN_TYPE_BEARER"
  access_token_role_assertion = false
  id_token_role_assertion     = false
  id_token_userinfo_assertion = false
  additional_origins          = []
  skip_native_app_success_page = false

  login_version {
    login_v2 {
      base_uri = "https://{{ terrarium_auth_domain }}/ui/v2/login/"
    }
  }
}

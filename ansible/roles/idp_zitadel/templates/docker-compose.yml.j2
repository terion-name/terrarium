services:
  zitadel-init:
    image: ghcr.io/zitadel/zitadel:{{ terrarium_zitadel_version }}
    restart: "no"
    user: "0"
    command: init
    environment: &zitadel-env
      ZITADEL_PORT: "8080"
      ZITADEL_EXTERNALDOMAIN: "{{ terrarium_auth_domain }}"
      ZITADEL_EXTERNALPORT: "443"
      ZITADEL_EXTERNALSECURE: "true"
      ZITADEL_TLS_ENABLED: "false"
      ZITADEL_DATABASE_POSTGRES_DSN: "postgresql://postgres:{{ terrarium_zitadel_postgres_password }}@postgres:5432/zitadel?sslmode=disable"
      ZITADEL_LOGSTORE_ACCESS_STDOUT_ENABLED: "true"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_USERNAME: "admin"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_FIRSTNAME: "Terrarium"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_LASTNAME: "Admin"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_EMAIL_ADDRESS: "{{ terrarium_zitadel_admin_email | default(terrarium_email, true) }}"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_EMAIL_VERIFIED: "true"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_PASSWORD: "{{ terrarium_zitadel_admin_password }}"
      ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED: "false"
      ZITADEL_FIRSTINSTANCE_MACHINEKEYPATH: /zitadel/bootstrap/admin-sa.json
      ZITADEL_FIRSTINSTANCE_PATPATH: /zitadel/bootstrap/admin-sa.pat
      ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME: terrarium-automation
      ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME: Terrarium Automation
      ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINEKEY_TYPE: "1"
      ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_EXPIRATIONDATE: "{{ terrarium_zitadel_pat_expiration }}"
      ZITADEL_FIRSTINSTANCE_LOGINCLIENTPATPATH: /zitadel/bootstrap/login-client.pat
      ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_USERNAME: login-client
      ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_NAME: Terrarium Login Client
      ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_PAT_EXPIRATIONDATE: "{{ terrarium_zitadel_pat_expiration }}"
      ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_REQUIRED: "true"
      ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_BASEURI: "https://{{ terrarium_auth_domain }}/ui/v2/login/"
      ZITADEL_OIDC_DEFAULTLOGINURLV2: "https://{{ terrarium_auth_domain }}/ui/v2/login/login?authRequest="
      ZITADEL_OIDC_DEFAULTLOGOUTURLV2: "https://{{ terrarium_auth_domain }}/ui/v2/login/logout?post_logout_redirect="
      ZITADEL_SAML_DEFAULTLOGINURLV2: "https://{{ terrarium_auth_domain }}/ui/v2/login/login?samlRequest="
    healthcheck:
      test:
        - CMD
        - /app/zitadel
        - ready
      interval: 10s
      timeout: 30s
      retries: 12
      start_period: 20s
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - "{{ terrarium_zitadel_bootstrap_dir }}:/zitadel/bootstrap:rw"
    networks:
      - zitadel

  zitadel-api:
    image: ghcr.io/zitadel/zitadel:{{ terrarium_zitadel_version }}
    restart: unless-stopped
    user: "0"
    command: start-from-setup --masterkey "{{ terrarium_zitadel_masterkey }}"
    environment:
      <<: *zitadel-env
    healthcheck:
      test:
        - CMD
        - /app/zitadel
        - ready
      interval: 10s
      timeout: 30s
      retries: 12
      start_period: 20s
    depends_on:
      postgres:
        condition: service_healthy
      zitadel-init:
        condition: service_completed_successfully
    ports:
      - "127.0.0.1:{{ terrarium_zitadel_api_port }}:8080"
    volumes:
      - "{{ terrarium_zitadel_bootstrap_dir }}:/zitadel/bootstrap:rw"
    networks:
      - zitadel

  zitadel-login:
    image: ghcr.io/zitadel/zitadel-login:{{ terrarium_zitadel_version }}
    restart: unless-stopped
    user: "0"
    environment:
      ZITADEL_API_URL: http://zitadel-api:8080
      NEXT_PUBLIC_BASE_PATH: /ui/v2/login
      ZITADEL_SERVICE_USER_TOKEN_FILE: /zitadel/bootstrap/login-client.pat
      CUSTOM_REQUEST_HEADERS: "Host:{{ terrarium_auth_domain }},X-Forwarded-Proto:https"
    healthcheck:
      test:
        - CMD
        - /bin/sh
        - -c
        - node /app/healthcheck.mjs http://localhost:3000/ui/v2/login/healthy
      interval: 10s
      timeout: 30s
      retries: 12
      start_period: 20s
    depends_on:
      zitadel-api:
        condition: service_healthy
    ports:
      - "127.0.0.1:{{ terrarium_zitadel_login_port }}:3000"
    volumes:
      - "{{ terrarium_zitadel_bootstrap_dir }}:/zitadel/bootstrap:ro"
    networks:
      - zitadel

  postgres:
    image: {{ terrarium_zitadel_postgres_image }}
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ terrarium_zitadel_postgres_password }}"
      POSTGRES_DB: zitadel
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -d zitadel -U postgres
      interval: 10s
      timeout: 30s
      retries: 10
      start_period: 20s
    volumes:
      - "{{ terrarium_zitadel_postgres_dir }}:/var/lib/postgresql/data:rw"
    networks:
      - zitadel

networks:
  zitadel:
    name: terrarium-zitadel
